# Sao chép thành `.env` rồi chỉnh giá trị (file `.env` không commit).

# --- Bắt buộc khi build production (GitHub Actions Variables trùng tên) ---
# URL API công khai — phải là URL ĐẦY ĐỦ https://.../api (không dùng /api tương đối).
# Nếu để trùng domain với site tĩnh hoặc /api tương đối, build sẽ fallback Render trong apiBase.js.
# GitHub Variables: nên set rõ https://<service>.onrender.com/api
VITE_API_BASE_URL=https://shopbandoao.onrender.com/api

# Đường dẫn gốc của site (Vite base). Custom domain gốc (ndsports.id.vn) → bắt buộc /
# Nếu không set, workflow mặc định /TênRepo/ — có thể làm 404 file CSS/JS trên domain gốc.
# VITE_BASE=/

# Google OAuth (Web client) — VITE_GOOGLE_CLIENT_ID
# Google Cloud → Credentials → OAuth client → Authorized redirect URIs, thêm CHÍNH XÁC:
#   https://<domain>/auth/google/callback   (và http://localhost:5173/auth/google/callback nếu có VITE_BASE=/)
# Nếu site dùng GitHub Pages với VITE_BASE=/TênRepo/, callback thực tế là:
#   https://<user>.github.io/TênRepo/auth/google/callback — phải thêm URI này trong Google Console.
# Tùy chọn: set URL đầy đủ để luôn khớp Console (tránh lệch do www / path):
# VITE_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback
# Render: GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET (secret chỉ backend)
VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
