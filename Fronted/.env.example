# Sao chép thành `.env` rồi chỉnh giá trị (file `.env` không commit).

# --- Bắt buộc khi build production (GitHub Actions Variables trùng tên) ---
# URL API công khai, luôn kết thúc bằng /api (NestJS route dạng /api/...)
# Ví dụ Render: https://ten-service.onrender.com/api
# Ví dụ VPS:    https://api.ndsports.id.vn/api
VITE_API_BASE_URL=https://YOUR-SERVICE.onrender.com/api

# Đường dẫn gốc của site (Vite base).
# Local / custom domain ndsports.id.vn: /
# Chỉ dùng *.github.io/ShopBanDoAo: /ShopBanDoAo/
# VITE_BASE=/

# Google OAuth (Google Cloud Console → OAuth 2.0 Client ID - Web)
VITE_GOOGLE_CLIENT_ID=871253844733-mk41pbthjgppmfq0knkuu4dipr3o80dv.apps.googleusercontent.com
