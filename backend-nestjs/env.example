# Sao chép thành .env (file .env không nên commit)

PORT=3000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/webbanhang

JWT_SECRET=thay-bang-chuoi-ngau-nhien-dai
JWT_EXPIRE=7d

# Đăng nhập Google — trùng VITE_GOOGLE_CLIENT_ID; secret lấy trong Google Cloud (OAuth client → Client secret)
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
