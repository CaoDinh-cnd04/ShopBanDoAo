# Sao chép thành `.env` (không commit). Trên Render: Environment → thêm biến.

MONGO_URI=
JWT_SECRET=

# VNPay — lấy từ https://sandbox.vnpayment.vn/ hoặc cổng production
# Return URL phải khớp CHÍNH XÁC URL đăng ký trên VNPay (https, không / thừa)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
# Phải trùng URL đăng ký Return URL trên VNPay (ví dụ production):
# VNPAY_RETURN_URL=https://ndsports.id.vn/api/payment/vnpay-return
VNPAY_RETURN_URL=https://your-api.onrender.com/api/payment/vnpay-return
# Site SPA — redirect sau thanh toán, link email. Có thể ghi nhiều origin (phẩy):
# dev → ưu tiên localhost; production (NODE_ENV=production) → ưu tiên domain public.
# FRONTEND_URL=http://localhost:5173,https://ndsports.id.vn
FRONTEND_URL=https://ndsports.id.vn

# Email nhận thông báo đơn hàng (admin). Nếu có, server gửi mail admin CHỈ tới đây (không dùng email user Admin trong DB).
# Tránh bounce khi tài khoản Admin trong MongoDB còn email/domain cũ (vd. admin@tdsport...).
# Nhiều địa chỉ: ADMIN_NOTIFY_EMAIL=a@gmail.com,b@gmail.com
ADMIN_NOTIFY_EMAIL=

# Email đặt hàng (Gmail: dùng App Password, không dùng mật khẩu thường)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Shop <noreply@example.com>"
# true = sandbox (https://sandbox.vnpayment.vn/...), false = production
VNPAY_SANDBOX=true

# Đặt sân — % cọc VNPAY (phần còn lại trả tại sân, không COD online)
BOOKING_DEPOSIT_PERCENT=30
BOOKING_DEPOSIT_MIN_VND=10000

# Google OAuth (nếu dùng)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
