# Server Configuration
PORT=3000
NODE_ENV=development

# Bắt buộc (validateEnv): MongoDB + JWT
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/SportsEcommerce?retryWrites=true&w=majority
# MONGODB_DB_NAME=SportsEcommerce

# (Legacy / không dùng nếu chỉ MongoDB)
# DB_SERVER=localhost
# DB_DATABASE=SportsEcommerce
# DB_USER=sa
# DB_PASSWORD=your_password
# DB_PORT=1433
# DB_OPTIONS_TRUST_SERVER_CERTIFICATE=true

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=7d

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Rate Limiting (Development)
# Set to 'true' to disable rate limiting in development (NOT recommended for production)
# DISABLE_RATE_LIMIT=false

# Firebase Configuration
# Option 1: Service Account file path (Development - Đang sử dụng)
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Option 2: Service Account JSON as string (recommended for production)
# Uncomment và paste toàn bộ JSON vào 1 dòng
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"sports-ecommerce-75e97",...}

# Option 3: Individual credentials (Alternative)
# FIREBASE_PROJECT_ID=sports-ecommerce-75e97
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@sports-ecommerce-75e97.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
